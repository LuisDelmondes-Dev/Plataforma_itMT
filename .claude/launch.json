{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "cwd": "api",
      "runtimeExecutable": "node",
      "runtimeArgs": ["dist/main.js"],
      "port": 3001,
      "env": { "DATABASE_URL": "postgres://itmt:itmt@localhost:5432/itmt" }
    },
    {
      "name": "web",
      "cwd": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "env": { "API_URL": "http://localhost:3001" }
    }
  ]
}
