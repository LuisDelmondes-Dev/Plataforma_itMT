DATABASE_URL=postgres://itmt:itmt@localhost:5432/itmt
PORT=3001
# IA Xingú (F2) — borda de linguagem (RG-02). Sem chave: intérprete léxico (RG-05).
ANTHROPIC_API_KEY=
XINGU_MODELO=claude-haiku-4-5
XINGU_PROVEDOR=auto   # auto | lexico
ADMIN_TOKEN=itmt-admin-dev

# ---- Produção (o main.ts valida e recusa subir sem isso) ----
# NODE_ENV=production
# DATABASE_URL=postgres://itmt_app:<segredo>@db:5432/itmt   # NUNCA o dono do banco (RG-10)
# ADMIN_TOKEN=<aleatório, >= 24 caracteres>
# CORS_ORIGEM=https://itmt.mt.gov.br
# RATE_LIMIT=1            # força rate limit fora de produção (testes de carga)
# RATE_LIMIT_SEG=20       # requisições/segundo por IP
# RATE_LIMIT_MIN=300      # requisições/minuto por IP

# ---- Cofre de segredos (AES-256-GCM + scrypt) ----
# Guarde a chave: node scripts/cofre.mjs guardar anthropic <chave> --senha <mestra>
# Em runtime, ITMT_COFRE_SENHA decifra .cofre/*.json em memória (nunca em disco).
# ITMT_COFRE_SENHA=<senha-mestra forte; gere com: node scripts/cofre.mjs gerar-senha>
# OPENAI_API_KEY=            # opcional: cascata de provedores (cofre: guardar openai <chave>)
# OPENAI_MODELO=gpt-4o-mini
# XINGU_PROVEDOR=auto        # auto | openai (OpenAI na frente) | lexico
# A15 — governador de custo do LLM (0 = ilimitado)
# XINGU_TETO_TOKENS_DIA=500000
# XINGU_TETO_TOKENS_MES=5000000

# ---- Identidade / RBAC (RF012) ----
# SESSION_SECRET assina os tokens de sessão (HMAC). Sem ele, cai no ADMIN_TOKEN (dev).
# SESSION_SECRET=<aleatório, >= 32 caracteres>
# Bootstrap do 1º admin (senha só aqui/no cofre, nunca em claro no banco):
# ADMIN_EMAIL=admin@itmt.local
# ADMIN_SENHA_INICIAL=<senha forte inicial; rotacione após o 1º login>
